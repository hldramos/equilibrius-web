---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Página não encontrada"
  description="A página que você procura não existe ou foi movida."
  noindex
>
  <section class="bg-ink-900 text-white py-20 md:py-32">
    <div class="max-w-[var(--container-max)] mx-auto px-6 text-center">
      <p class="font-display text-6xl md:text-8xl font-bold text-white">404</p>
      <h1 class="font-display text-2xl md:text-3xl font-semibold mt-6 max-w-xl mx-auto">
        Página não encontrada.
      </h1>
      <p class="mt-4 text-silver-300 max-w-md mx-auto">
        A página que você procura pode ter sido movida ou não existe.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-ink-900 bg-white rounded-md hover:bg-silver-100 transition-colors"
        >
          Voltar ao início
        </a>
        <a
          href="/contato"
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white border border-ink-500 rounded-md hover:bg-ink-700 transition-colors"
        >
          Falar com especialista
        </a>
      </div>
    </div>
  </section>
</BaseLayout>