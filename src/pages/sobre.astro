---
import BaseLayout from "../layouts/BaseLayout.astro";
import StepList from "../components/StepList.astro";
import CtaBlock from "../components/CtaBlock.astro";
import { SITE } from "../lib/site";

const methodSteps = [
  { title: "Diagnóstico", description: "Revisamos impostos, regime tributário e obrigações atuais." },
  { title: "Proposta", description: "Caminhos com base legal e impacto previsto — você decide." },
  { title: "Execução", description: "Implementamos e documentamos cada passo do trabalho." },
  { title: "Acompanhamento", description: "Monitoramos prazos e avisamos antes do vencimento." },
];
---

<BaseLayout
  title="Sobre a EQUILIBRIUS · Consultoria contábil e tributária"
  description="Quem somos, como trabalhamos e no que acreditamos — consultoria consultiva, estratégica e preventiva, baseada em Feira de Santana, atendendo todo o Brasil."
  path="/sobre"
  type="profile"
>
  <section class="bg-ink-900 text-white py-16 md:py-24">
    <div class="max-w-[var(--container-max)] mx-auto px-6">
      <h1 class="font-display text-3xl md:text-5xl font-semibold leading-tight max-w-3xl">
        Consultoria tributária e contábil com método, não improviso.
      </h1>
      <p class="mt-6 text-lg text-silver-200 leading-relaxed max-w-2xl">
        A EQUILIBRIUS é um escritório virtual baseado em Feira de Santana (BA),
        que atende empresas em todo o Brasil. Nossa voz é consultiva, estratégica
        e preventiva — focada em soluções tributárias e contábeis com base legal.
      </p>
    </div>
  </section>

  <!-- Manifesto -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-[var(--container-max)] mx-auto px-6">
      <div class="max-w-3xl space-y-6 text-lg text-graphite leading-relaxed">
        <p>
          O nome EQUILIBRIUS reflete o que buscamos entregar: equilíbrio entre
          conformidade fiscal e resultado financeiro do cliente. Não defendemos
          sonegação nem aceitamos omissão — defendemos o pagamento do imposto
          correto, nem mais, nem menos.
        </p>
        <p>
          Em 5 anos de atuação, aprendemos que o empresário brasileiro não
          precisa de mais um contador reativo que apenas entrega obrigações no
          prazo. Precisa de alguém que entenda o negócio, antecipe problemas e
          explique tributos em linguagem acessível.
        </p>
        <p>
          Por isso operamos como escritório virtual: sem barreira geográfica, sem
          necessidade de deslocamento, com troca documental 100% digital. Para
          empresas de qualquer cidade do Brasil.
        </p>
      </div>
    </div>
  </section>

  <!-- Método -->
  <section class="py-16 md:py-24 bg-silver-50">
    <div class="max-w-[var(--container-max)] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h2 class="font-display text-3xl md:text-4xl font-semibold text-ink-900 mb-4">
            O método da Equilibrius
          </h2>
          <p class="text-lg text-graphite leading-relaxed">
            Um processo estruturado, não uma coleção de tarefas soltas. Do
            diagnóstico ao acompanhamento contínuo.
          </p>
        </div>
        <StepList steps={methodSteps} />
      </div>
    </div>
  </section>

  <!-- Equipe [VALIDAR] -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-[var(--container-max)] mx-auto px-6">
      <div class="max-w-2xl mb-10">
        <h2 class="font-display text-3xl md:text-4xl font-semibold text-ink-900 mb-4">
          Equipe
        </h2>
        <p class="text-sm text-graphite-light italic">
          [Conteúdo a validar — fotos, nomes, credenciais (CRC) dos responsáveis técnicos.]
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-silver-50 border border-silver-200 rounded-lg p-6">
          <div class="w-16 h-16 rounded-full bg-silver-200 mb-4"></div>
          <h3 class="font-display font-semibold text-base text-ink-900">[Responsável técnico]</h3>
          <p class="text-sm text-graphite-light mt-1">[Função · CRC a confirmar]</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Credenciais -->
  <section class="py-12 bg-silver-50 border-y border-silver-200">
    <div class="max-w-[var(--container-max)] mx-auto px-6">
      <h2 class="font-display text-xl font-semibold text-ink-900 mb-4">Credenciais e transparência</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
        <div>
          <p class="text-graphite-light">Razão social</p>
          <p class="text-ink-900 font-medium">{SITE.fullName}</p>
          <p class="text-xs text-graphite-light italic mt-1">[Confirmar razão social completa no CNPJ {SITE.cnpj}]</p>
        </div>
        <div>
          <p class="text-graphite-light">CNPJ</p>
          <p class="text-ink-900 font-medium">{SITE.cnpj}</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBlock
    title="Falar com a Equilibrius"
    subtitle="Tire sua dúvida com quem decide. Atendimento em todo o Brasil."
    serviceSlug="sobre"
    submitText="Iniciar conversa"
  />
</BaseLayout>