---
import BaseLayout from "../layouts/BaseLayout.astro";
import LeadFormShort from "../components/LeadFormShort.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE } from "../lib/site";
import { organizationSchema } from "../lib/seo";
---

<BaseLayout
  title="Fale com a EQUILIBRIUS · Contato"
  description="Fale com a Equilibrius — consultoria tributária e contábil em todo o Brasil. WhatsApp, e-mail e formulário. Atendimento Seg–Sex, 08h–17h30."
  path="/contato"
  jsonLd={organizationSchema()}
>
  <section class="bg-ink-900 text-white py-16 md:py-24">
    <div class="max-w-[var(--container-max)] mx-auto px-6">
      <h1 class="font-display text-3xl md:text-5xl font-semibold leading-tight">
        Fale com a Equilibrius
      </h1>
      <p class="mt-4 text-lg text-silver-200 max-w-2xl leading-relaxed">
        Atendimento em todo o Brasil. Sem necessidade de deslocamento —
        reuniões por call e troca documental digital.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-[var(--container-max)] mx-auto px-6">
      <Breadcrumbs trail={[{ name: "Início", href: "/" }, { name: "Contato", href: "/contato" }]} />

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Form -->
        <div>
          <div id="form-feedback" class="hidden"></div>

          <h2 class="font-display text-2xl md:text-3xl font-semibold text-ink-900 mb-6">
            Envie sua mensagem
          </h2>
          <LeadFormShort
            context="contato"
            submitText="Enviar mensagem"
            variant="card"
          />
        </div>

        <!-- Canais -->
        <div class="lg:pl-8">
          <h2 class="font-display text-2xl md:text-3xl font-semibold text-ink-900 mb-6">
            Outros canais
          </h2>
          <ul class="space-y-6 text-base">
            <li>
              <a
                href={SITE.whatsappLink}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-start gap-4 group"
              >
                <span class="flex items-center justify-center w-11 h-11 rounded-full bg-whatsapp/10 text-whatsapp shrink-0">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 21.785h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884M20.438 3.42A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </span>
                <span>
                  <span class="block font-semibold text-ink-900 group-hover:text-ink-700 transition-colors">WhatsApp</span>
                  <span class="text-graphite">{SITE.whatsapp}</span>
                </span>
              </a>
            </li>

            <li>
              <a href={`mailto:${SITE.email}`} class="flex items-start gap-4 group">
                <span class="flex items-center justify-center w-11 h-11 rounded-full bg-ink-700/10 text-ink-700 shrink-0">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke-linecap="round"/>
                    <path d="M22 6l-10 7L2 6" stroke-linecap="round"/>
                  </svg>
                </span>
                <span>
                  <span class="block font-semibold text-ink-900 group-hover:text-ink-700 transition-colors">E-mail</span>
                  <span class="text-graphite break-all">{SITE.email}</span>
                </span>
              </a>
            </li>

            <li class="flex items-start gap-4">
              <span class="flex items-center justify-center w-11 h-11 rounded-full bg-ink-700/10 text-ink-700 shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2" stroke-linecap="round"/>
                </svg>
              </span>
              <span>
                <span class="block font-semibold text-ink-900">Horário</span>
                <span class="text-graphite">{SITE.hours}</span>
              </span>
            </li>

            <li class="flex items-start gap-4">
              <span class="flex items-center justify-center w-11 h-11 rounded-full bg-ink-700/10 text-ink-700 shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-linecap="round"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </span>
              <span>
                <span class="block font-semibold text-ink-900">Base</span>
                <span class="text-graphite">{SITE.city} — {SITE.state}</span>
                <span class="block text-sm text-graphite-light mt-1">
                  Escritório virtual — atendemos empresas em todo o Brasil.
                </span>
              </span>
            </li>
          </ul>

          <div class="mt-10 p-5 bg-silver-50 rounded-lg text-sm text-graphite">
            <p>
              Seus dados são tratados conforme a <a href="/politica-de-privacidade" class="text-ink-600 hover:text-ink-700 underline underline-offset-2">Política de Privacidade</a>.
              Respondemos em até 1 dia útil.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const feedback = document.getElementById("form-feedback");
  if (params.has("enviado") && feedback) {
    feedback.className = "p-4 mb-6 text-sm font-medium text-white bg-success rounded-lg";
    feedback.textContent = "Mensagem enviada com sucesso. Responderemos em até 1 dia útil.";
    if (window.history.replaceState) {
      window.history.replaceState({}, "", "/contato");
    }
  }
  if (params.has("erro") && feedback) {
    const msgs = {
      campos_obrigatorios: "Preencha nome e pelo menos um contato (telefone ou e-mail).",
      email_invalido: "E-mail informado não é válido.",
      envio_falhou: "Erro ao enviar. Tente novamente ou fale pelo WhatsApp.",
    };
    feedback.className = "p-4 mb-6 text-sm font-medium text-white bg-error rounded-lg";
    feedback.textContent = msgs[params.get("erro")] || "Erro ao enviar. Tente novamente.";
  }
</script>