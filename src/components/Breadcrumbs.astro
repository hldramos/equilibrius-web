---
interface Props {
  trail: { name: string; href: string }[];
}

const { trail } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm mb-6">
  <ol class="flex items-center gap-2 flex-wrap">
    {trail.map((item, i) => (
      <li class="flex items-center gap-2">
        {i > 0 && (
          <span class="text-silver-300">/</span>
        )}
        {i < trail.length - 1 ? (
          <a href={item.href} class="text-graphite-light hover:text-ink-700 transition-colors">
            {item.name}
          </a>
        ) : (
          <span class="text-ink-900 font-medium" aria-current="page">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>