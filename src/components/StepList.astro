---
interface Step {
  title: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<ol class="space-y-8">
  {steps.map((step, i) => (
    <li class="flex gap-5">
      <div class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-ink-900 text-white font-display font-semibold text-base">
        {i + 1}
      </div>
      <div class="pt-1.5">
        <h3 class="font-display font-semibold text-lg text-ink-900">{step.title}</h3>
        <p class="mt-1 text-sm text-graphite leading-relaxed">{step.description}</p>
      </div>
    </li>
  ))}
</ol>