---
interface Props {
  title: string;
  body: string;
  cite?: string;
}

const { title, body, cite } = Astro.props;
---

<aside class="bg-silver-50 border-l-4 border-ink-700 rounded-r-lg p-5 md:p-6 my-8">
  <h3 class="font-display font-semibold text-base text-ink-900 mb-2 flex items-center gap-2">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-700">
      <path d="M4 6h16M4 12h16M4 18h10" stroke-linecap="round" />
    </svg>
    {title}
  </h3>
  <p class="text-sm text-graphite leading-relaxed">{body}</p>
  {cite && (
    <p class="mt-3 text-xs text-graphite-light italic">{cite}</p>
  )}
</aside>