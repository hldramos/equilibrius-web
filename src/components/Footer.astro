---
import { SITE, NAV_LINKS } from "../lib/site";

const year = new Date().getFullYear();
---

<footer class="bg-ink-900 text-silver-200">
  <div class="max-w-[var(--container-max)] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <span class="font-display text-2xl font-bold text-white tracking-tight">
          EQUILIBRIUS
        </span>
        <p class="mt-4 text-sm text-silver-300 max-w-sm leading-relaxed">
          Consultoria tributária e contábil baseada em Feira de Santana (BA),
          atendendo empresas em todo o Brasil.
        </p>
        <p class="mt-4 text-xs text-silver-300/70">
          {SITE.fullName}<br />
          CNPJ {SITE.cnpj}
        </p>
      </div>

      <!-- Navegação -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Navegação
        </h3>
        <ul class="space-y-2">
          {NAV_LINKS.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-silver-300 hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/politica-de-privacidade" class="text-sm text-silver-300 hover:text-white transition-colors">
              Política de Privacidade
            </a>
          </li>
          <li>
            <a href="/termos-de-uso" class="text-sm text-silver-300 hover:text-white transition-colors">
              Termos de Uso
            </a>
          </li>
        </ul>
      </div>

      <!-- Contato -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Contato
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href={SITE.whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm text-silver-300 hover:text-white transition-colors"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-whatsapp">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {SITE.whatsapp}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${SITE.email}`}
              class="flex items-center gap-2 text-sm text-silver-300 hover:text-white transition-colors break-all"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M22 6l-10 7L2 6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {SITE.email}
            </a>
          </li>
          <li class="flex items-start gap-2 text-sm text-silver-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 shrink-0">
              <circle cx="12" cy="12" r="10" stroke-linecap="round"/>
              <path d="M12 6v6l4 2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{SITE.hours}</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-silver-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 shrink-0">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="10" r="3" stroke-linecap="round"/>
            </svg>
            <span>{SITE.city} — {SITE.state}<br />Atendimento em todo o Brasil</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-ink-700 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-silver-300/60">
        © {year} {SITE.fullName}. Todos os direitos reservados.
      </p>
      <p class="text-xs text-silver-300/60">
        Seus dados são tratados conforme a LGPD.
      </p>
    </div>
  </div>
</footer>